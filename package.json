{
  "name": "philosophy-mcp",
  "version": "0.3.0",
  "description": "MCP server for philosophy texts — PhilPapers/PhilArchive scholarship plus public-domain classics (Project Gutenberg, Internet Archive, Wikisource), open-access books (DOAB), modern editions (Open Library), and the Stanford Encyclopedia of Philosophy. No API key required.",
  "type": "module",
  "bin": {
    "philosophy-mcp": "dist/index.js",
    "philpapers-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "philosophy",
    "philpapers",
    "philarchive",
    "openalex",
    "project-gutenberg",
    "internet-archive",
    "wikisource",
    "open-library",
    "doab",
    "stanford-encyclopedia"
  ],
  "author": "sea9401",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sea9401/philpapers-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/sea9401/philpapers-mcp/issues"
  },
  "homepage": "https://github.com/sea9401/philpapers-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fast-xml-parser": "^5.8.0",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "typescript": "^5.9.3"
  }
}
